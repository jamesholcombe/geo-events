{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HTTP /v1/ingest response event item",
  "description": "Matches http-adapter EventJson. assignment_changed may omit region when null (skip_serializing_if).",
  "oneOf": [
    {
      "type": "object",
      "required": ["event", "id", "geofence", "t"],
      "properties": {
        "event": { "const": "enter" },
        "id": { "type": "string" },
        "geofence": { "type": "string" },
        "t": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["event", "id", "geofence", "t"],
      "properties": {
        "event": { "const": "exit" },
        "id": { "type": "string" },
        "geofence": { "type": "string" },
        "t": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["event", "id", "corridor", "t"],
      "properties": {
        "event": { "const": "enter_corridor" },
        "id": { "type": "string" },
        "corridor": { "type": "string" },
        "t": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["event", "id", "corridor", "t"],
      "properties": {
        "event": { "const": "exit_corridor" },
        "id": { "type": "string" },
        "corridor": { "type": "string" },
        "t": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["event", "id", "zone", "t"],
      "properties": {
        "event": { "const": "approach" },
        "id": { "type": "string" },
        "zone": { "type": "string" },
        "t": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["event", "id", "zone", "t"],
      "properties": {
        "event": { "const": "recede" },
        "id": { "type": "string" },
        "zone": { "type": "string" },
        "t": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["event", "id", "t"],
      "properties": {
        "event": { "const": "assignment_changed" },
        "id": { "type": "string" },
        "region": { "type": "string" },
        "t": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    }
  ]
}
