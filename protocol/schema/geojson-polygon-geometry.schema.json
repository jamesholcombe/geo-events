{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GeoJSON Polygon geometry (fragment)",
  "description": "Loose structural check only; does not validate ring closure, winding, or CRS.",
  "$defs": {
    "Position2D": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "number" }
    },
    "LinearRing": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/Position2D" }
    },
    "PolygonGeometry": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "Polygon" },
        "coordinates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/LinearRing" }
        }
      },
      "additionalProperties": true
    }
  }
}
